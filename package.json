{
  "name": "engine-scanner",
  "version": "1.0.0",
  "description": "AI-powered car engine diagnostic desktop app",
  "main": "main.js",
  "author": "EngineAI",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win msi",
    "build:win": "electron-builder --win msi",
    "build:mac": "electron-builder --mac dmg",
    "build:linux:rpm": "electron-builder --linux rpm",
    "build:linux:pacman": "electron-builder --linux pacman",
    "build:all": "electron-builder --win msi --mac dmg --linux rpm pacman"
  },
  "build": {
    "appId": "com.engineai.scanner",
    "productName": "EngineAI",
    "win": { "target": "msi", "icon": "icon.ico" },
    "msi": { "oneClick": false, "perMachine": false },
    "mac": { "target": "dmg", "icon": "icon.png", "category": "public.app-category.utilities" },
    "linux": {
      "target": ["rpm", "pacman"],
      "icon": "icon.png",
      "category": "Utility",
      "maintainer": "EngineAI",
      "description": "AI-powered car engine diagnostic desktop app"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "settings.js",
      "profile.js",
      "lua-runner.js",
      "automation.lua",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@azure-rest/ai-inference": "latest",
    "@azure/core-auth": "latest",
    "@azure/core-sse": "latest",
    "fengari": "^0.1.4"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
